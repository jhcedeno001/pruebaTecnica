# Aplicacion
APP_NAME=API Riesgo Proveedores
DEBUG=True
CORS_ORIGINS=["http://localhost:5173"]

# Base de datos (Postgres, driver async asyncpg).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=riesgo_proveedores
DB_USER=postgres
DB_PASSWORD=postgres123

# countries.dev
COUNTRIES_API_BASE_URL=https://countries.dev
COUNTRIES_API_TIMEOUT_SECONDS=50

# Tipos de cambio
EXCHANGE_RATE_PRIMARY_URL=https://cdn.jsdelivr.net/npm/@fawazahmed0/currency-api@{version}/v1/currencies/usd.json
EXCHANGE_RATE_FALLBACK_URL=https://{version}.currency-api.pages.dev/v1/currencies/usd.json
EXCHANGE_RATE_API_TIMEOUT_SECONDS=50

# Dataset de referencia geografica (landlocked)
GEO_REFERENCE_DATASET_URL=https://cdn.jsdelivr.net/gh/mledoze/countries@master/dist/countries.json
GEO_REFERENCE_API_TIMEOUT_SECONDS=50

# Conflictos armados activos por pais
CONFLICTS_DATASET_URL=https://ourworldindata.org/grapher/locations-of-ongoing-armed-conflicts.csv?csvType=full&useColumnShortNames=true
CONFLICTS_API_TIMEOUT_SECONDS=50

# Resiliencia de los clientes HTTP externos: circuit breaker + rate limit.
HTTP_BREAKER_FAIL_MAX=5
HTTP_BREAKER_RESET_TIMEOUT_SECONDS=30
HTTP_RATE_LIMIT_PER_SECOND=5
